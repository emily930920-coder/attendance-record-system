# 环境变量示例文件
# 复制此文件为 .env 并修改配置

# 服务器端口
PORT=3000

# 运行环境
NODE_ENV=production

# 数据目录（可选，默认为 server/data）
# DATA_DIR=/path/to/data

# 启用调试模式（可选）
# DEBUG=true

# ===== 备份配置（用于Render部署） =====

# 主备份Webhook（推荐使用 webhook.site 或 Pipedream）
# BACKUP_WEBHOOK_URL=https://webhook.site/your-unique-url

# Discord Webhook（可选）
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# 邮件Webhook（可选，使用 Mailgun、SendGrid等服务）
# EMAIL_WEBHOOK_URL=https://your-email-webhook-service.com/send

# Slack Webhook（可选）
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your-webhook-url
