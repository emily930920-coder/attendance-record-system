# Discord备份配置（可选，但推荐）
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/你的Webhook_ID/你的Webhook_Token

# GitHub API自动备份配置
# Render等云平台使用此方案
ENABLE_GIT_BACKUP=true
GITHUB_TOKEN=ghp_你的GitHub_Personal_Access_Token
GITHUB_OWNER=你的GitHub用户名
GITHUB_REPO=你的仓库名
GITHUB_BRANCH=main

# 可选：通用Webhook备份
# BACKUP_WEBHOOK_URL=https://webhook.site/你的ID
